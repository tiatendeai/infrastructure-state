services:
  n8n:
    image: {{ shipyard_images.n8n }}
    container_name: ruptur-n8n
    restart: unless-stopped
    environment:
      N8N_HOST: {{ shipyard_domains.n8n | quote }}
      N8N_PROTOCOL: "https"
      N8N_PORT: "5678"
      N8N_EDITOR_BASE_URL: {{ ('https://' ~ shipyard_domains.n8n) | quote }}
      WEBHOOK_URL: {{ ('https://' ~ shipyard_domains.n8n ~ '/') | quote }}
      N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS: "true"
      GENERIC_TIMEZONE: {{ shipyard_timezone | quote }}
      N8N_ENCRYPTION_KEY: {{ shipyard_n8n_encryption_key | quote }}
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: postgres
      DB_POSTGRESDB_PORT: "5432"
      DB_POSTGRESDB_DATABASE: {{ shipyard_n8n_db | quote }}
      DB_POSTGRESDB_USER: {{ shipyard_n8n_user | quote }}
      DB_POSTGRESDB_PASSWORD: {{ shipyard_n8n_password | quote }}
    volumes:
      - {{ shipyard_data_dir }}/n8n:/home/node/.n8n
    networks:
      - edge
      - data
    labels:
      traefik.enable: "true"
      traefik.docker.network: "ruptur-edge"
      traefik.http.routers.n8n.rule: Host(`{{ shipyard_domains.n8n }}`)
      traefik.http.routers.n8n.entrypoints: websecure
      traefik.http.routers.n8n.tls: "true"
      traefik.http.routers.n8n.tls.certresolver: letsencrypt
      traefik.http.services.n8n.loadbalancer.server.port: "5678"

networks:
  edge:
    external: true
    name: ruptur-edge
  data:
    external: true
    name: ruptur-data
