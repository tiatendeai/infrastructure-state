# Ruptur SaaS - Environment Variables
# Copie este arquivo para .env e preencha com valores reais

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# UAZAPI
UAZAPI_TOKEN=your-uazapi-token

# OpenAI (opcional)
OPENAI_API_KEY=sk-your-openai-key

# Runtime
WARMUP_RUNTIME_HOST=0.0.0.0
WARMUP_RUNTIME_PORT=4173
NODE_ENV=production
