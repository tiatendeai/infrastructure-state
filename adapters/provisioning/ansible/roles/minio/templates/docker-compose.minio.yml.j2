services:
  minio:
    image: {{ shipyard_images.minio }}
    container_name: ruptur-minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: {{ shipyard_minio_root_user | quote }}
      MINIO_ROOT_PASSWORD: {{ shipyard_minio_root_password | quote }}
    volumes:
      - {{ shipyard_data_dir }}/minio:/data
    networks:
      - data

networks:
  data:
    external: true
    name: ruptur-data
