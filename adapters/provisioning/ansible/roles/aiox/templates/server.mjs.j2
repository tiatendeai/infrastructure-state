      <p class="meta subtle">Este espaço é a casa operacional do AIOX: bridge, teste e retorno ao home. Não substitui o HITL, só entra e sai quando precisa.</p>
    </main>
    <script>
      const button = document.getElementById("send");
      const promptEl = document.getElementById("prompt");
      const output = document.getElementById("output");
      button.addEventListener("click", async () => {
        output.textContent = "Processando...";
        try {
          const response = await fetch("/api/hermes/chat", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ prompt: promptEl.value })
          });
          const raw = await response.text();
          const contentType = response.headers.get("content-type") || "";
          if (contentType.includes("application/json")) {
            try {
              output.textContent = JSON.stringify(JSON.parse(raw), null, 2);
              return;
            } catch (parseError) {
              output.textContent = `JSON inválido na resposta (${response.status}): ${String(parseError)}\n\n${raw}`;
              return;
            }
          }
          output.textContent = `Resposta não-JSON (${response.status}, ${contentType || "sem content-type"}):\n\n${raw}`;
        } catch (error) {
          output.textContent = String(error);
        }
      });
    </script>
