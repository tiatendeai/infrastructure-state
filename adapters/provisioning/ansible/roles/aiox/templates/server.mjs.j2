async function refreshHermes(promptText = "ping") {
  state.hermes.lastCheckedAt = new Date().toISOString();
  try {
    const result = await checkHermes(promptText);
    state.hermes.status = result.ok ? "ok" : "error";
    state.hermes.lastError = result.ok ? null : `HTTP ${result.status}`;
    state.hermes.lastResponse = result.body;
    return result;
  } catch (error) {
    state.hermes.status = "error";
    state.hermes.lastError = error instanceof Error ? error.message : String(error);
    state.hermes.lastResponse = null;
    return { ok: false, error: state.hermes.lastError };
  }
}

bootstrapAiox()
  .then(() => refreshHermes("Ollama e Hermes estão conectados?"))
  .catch((error) => {
    state.installOutput = state.installOutput || "";
    state.doctorOutput = `${state.doctorOutput ? `${state.doctorOutput}\n` : ""}BOOTSTRAP_ERROR: ${error instanceof Error ? error.stack || error.message : String(error)}`;
    state.bootstrapWarnings.push("bootstrap_error");
    state.bootstrapped = false;
    state.bootstrapFinishedAt = new Date().toISOString();
  });

const server = http.createServer(async (req, res) => {
  const url = new URL(req.url || "/", `http://${req.headers.host || "localhost"}`);

  if ((req.method === "GET" || req.method === "HEAD") && url.pathname === "/health") {
    res.writeHead(200, { "content-type": "application/json; charset=utf-8" });
    if (req.method === "HEAD") {
      res.end();
      return;
    }
    res.end(JSON.stringify({
      ok: true,
      service: "aiox-bridge",
      bootstrapped: state.bootstrapped,
      aioxVersion: state.aioxVersion,
      hermes: state.hermes,
    }, null, 2));
    return;
  }

  if (req.method === "POST" && url.pathname === "/api/hermes/chat") {
    const chunks = [];
    for await (const chunk of req) chunks.push(chunk);
    let payload = {};
    try {
      payload = JSON.parse(Buffer.concat(chunks).toString("utf-8") || "{}");
    } catch {
      payload = {};
    }
    const prompt = String(payload.prompt || "ping");
    const result = await refreshHermes(prompt);
    res.writeHead(result.ok ? 200 : 502, { "content-type": "application/json; charset=utf-8" });
    res.end(JSON.stringify(result, null, 2));
    return;
  }

  if ((req.method === "GET" || req.method === "HEAD") && url.pathname === "/api/status") {
    res.writeHead(200, { "content-type": "application/json; charset=utf-8" });
    if (req.method === "HEAD") {
      res.end();
      return;
    }
    res.end(JSON.stringify({
      ok: true,
      state,
      publicBaseUrl: PUBLIC_BASE_URL,
    }, null, 2));
    return;
  }

  if ((req.method === "GET" || req.method === "HEAD") && url.pathname === "/") {
    res.writeHead(200, { "content-type": "text/html; charset=utf-8" });
    if (req.method === "HEAD") {
      res.end();
      return;
    }
    res.end(renderPage());
    return;
  }

  res.writeHead(404, { "content-type": "application/json; charset=utf-8" });
  res.end(JSON.stringify({ ok: false, error: "not_found" }, null, 2));
});

server.listen(PORT, "0.0.0.0", () => {
  console.log(`[aiox-bridge] listening on ${PORT}`);
});
