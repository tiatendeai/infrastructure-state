      textarea, button, input { width: 100%; box-sizing: border-box; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.06); color: #e5eefb; padding: 12px 14px; font: inherit; }
      textarea { min-height: 140px; }
      button { cursor: pointer; background: linear-gradient(135deg, #7c3aed, #06b6d4); font-weight: 700; }
      pre { white-space: pre-wrap; word-break: break-word; background: #08101d; padding: 16px; border-radius: 14px; overflow: auto; }
      .meta { color: #9db0d0; font-size: 14px; line-height: 1.5; }
      .pill { display:inline-block; padding: 6px 10px; border-radius: 999px; background: rgba(34,197,94,0.15); color: #86efac; font-weight: 700; }
      .warn { background: rgba(245,158,11,0.15); color: #fbbf24; }
      a { color: #93c5fd; }
      .subtle { color: #9db0d0; }
    </style>
  </head>
  <body>
    <main>
      <h1>AIOX Shipyard Bridge</h1>
      <p class="meta">Casa própria do AIOX, separada do cockpit HITL e pronta para hotswap por projeto.</p>
      <p class="meta">
        Subdomínio: <strong>${htmlEscape(PUBLIC_BASE_URL)}</strong> ·
        Home canônica: <a href="https://hitl.ruptur.cloud" target="_blank" rel="noreferrer">hitl.ruptur.cloud</a> ·
        Estado: <span class="pill ${state.bootstrapped ? "" : "warn"}">${htmlEscape(status)}</span>
      </p>

      <div class="grid">
      <section class="card">
        <h2>Status do AIOX</h2>
        <p class="meta">Versão detectada: <strong>${htmlEscape(state.aioxVersion || "pendente")}</strong></p>
        <p class="meta">Bootstrap: <strong>${htmlEscape(state.bootstrapStartedAt || "pendente")}</strong> → <strong>${htmlEscape(state.bootstrapFinishedAt || "pendente")}</strong></p>
        <p class="meta">Warnings: <strong>${htmlEscape((state.bootstrapWarnings || []).join(", ") || "nenhum")}</strong></p>
        <p class="meta">Projeto: <code>${htmlEscape(PROJECT_DIR)}</code></p>
        <p class="meta">Home: <code>${htmlEscape(AIOX_HOME)}</code></p>
      </section>

        <section class="card">
          <h2>Hermes/Ollama</h2>
          <p class="meta">Base URL: <code>${htmlEscape(HERMES_BASE_URL)}</code></p>
          <p class="meta">Perfil ativo: <code>${htmlEscape(AIOX_MODEL_PROFILE)}</code></p>
          <p class="meta">Model: <code>${htmlEscape(AIOX_MODEL)}</code></p>
          <p class="meta">Endpoint: <code>${htmlEscape(HERMES_CHAT_PATH)}</code></p>
          <p class="meta">Último check: <strong>${htmlEscape(state.hermes.lastCheckedAt || "nunca")}</strong></p>
          <p class="meta">Estado: <strong>${htmlEscape(state.hermes.status)}</strong></p>
        </section>
      </div>

      <section class="card">
        <h2>Teste Hermes</h2>
        <textarea id="prompt" placeholder="Escreva uma mensagem de teste para Hermes...">Oi Hermes, responde com uma frase curta dizendo que o motor está vivo no Shipyard.</textarea>
        <div style="height: 10px;"></div>
        <button id="send">Enviar teste</button>
        <div style="height: 16px;"></div>
        <pre id="output">Aguardando teste…</pre>
      </section>

      <section class="card">
        <h2>Saída do install</h2>
        <pre>${install}</pre>
