PORT={{ jarvis_port }}
JARVIS_PORT={{ jarvis_port }}
NODE_ENV=production
MAESTRO_WATCH_PATH=/state
GCP_PROJECT_ID={{ jarvis_google_project_id }}
GCP_REGION={{ jarvis_google_region }}
GOOGLE_APPLICATION_CREDENTIALS={{ jarvis_google_credentials_path }}

UAZAPI_BASE_URL={{ jarvis_uazapi_base_url }}
ADMIN_TOKEN={{ shipyard_jarvis_uazapi_admin_token | default('') }}
INSTANCE_TOKEN={{ shipyard_jarvis_uazapi_instance_token | default('') }}
WHATSAPP_ALLOWED_USER_IDS={{ shipyard_jarvis_allowed_user_ids | default('') }}
JARVIS_PUBLIC_WEBHOOK_URL={{ jarvis_public_base_url }}/webhook

CORE_PROVIDER={{ jarvis_core_provider }}
ROUTER_PROVIDER={{ jarvis_router_provider }}
GEMINI_API_KEY={{ shipyard_jarvis_gemini_api_key | default('') }}
OPENROUTER_API_KEY={{ shipyard_jarvis_openrouter_api_key | default('') }}
GROQ_API_KEY={{ shipyard_jarvis_groq_api_key | default('') }}
DEEPSEEK_API_KEY={{ shipyard_jarvis_deepseek_api_key | default('') }}
{% if jarvis_core_provider == 'ollama' %}
JARVIS_MODEL=ollama_chat/{{ jarvis_ollama_model }}
OLLAMA_API_BASE={{ jarvis_ollama_base_url | replace('/v1', '') }}
{% endif %}
{% if jarvis_session_service_uri is defined and jarvis_session_service_uri %}
JARVIS_SESSION_SERVICE_URI={{ jarvis_session_service_uri }}
{% endif %}

OLLAMA_BASE_URL={{ jarvis_ollama_base_url }}
OLLAMA_MODEL={{ jarvis_ollama_model }}
