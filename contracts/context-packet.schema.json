{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ruptur Context Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "branch",
    "linear_issue",
    "task",
    "objective",
    "latest_actions",
    "canonical_facts",
    "retrieved_memories",
    "policy_refs"
  ],
  "properties": {
    "project": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string"
    },
    "memory_backend": {
      "type": "string",
      "enum": [
        "mock",
        "redis",
        "supabase"
      ]
    },
    "linear_issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identifier",
        "title"
      ],
      "properties": {
        "identifier": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "task_id",
        "mode"
      ],
      "properties": {
        "task_id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "FAST",
            "STANDARD",
            "FULL"
          ]
        },
        "source": {
          "type": "string"
        }
      }
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "latest_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "canonical_facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retrieved_memories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "memory_id",
          "layer",
          "summary",
          "source"
        ],
        "properties": {
          "memory_id": {
            "type": "string"
          },
          "layer": {
            "type": "string",
            "enum": [
              "raw_event",
              "summary",
              "canonical_memory"
            ]
          },
          "title": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "source": {
            "type": "string"
          }
        }
      }
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
