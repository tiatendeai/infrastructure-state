{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ruptur State",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "context_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "max_files",
        "max_chars",
        "prefer_diffs",
        "prefer_whitelist",
        "heartbeat_seconds_min",
        "allow_repo_rediscovery"
      ],
      "properties": {
        "path": { "type": "string" },
        "max_files": { "type": "integer", "minimum": 0 },
        "max_chars": { "type": "integer", "minimum": 0 },
        "prefer_diffs": { "type": "boolean" },
        "prefer_whitelist": { "type": "boolean" },
        "heartbeat_seconds_min": { "type": "integer", "minimum": 0 },
        "allow_repo_rediscovery": { "type": "boolean" }
      }
    },
    "context_refs": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["status", "current_task", "history", "version"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["idle", "running", "error"]
    },
    "current_task": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["task_id", "type", "mode"],
          "properties": {
            "task_id": { "type": "string" },
            "type": { "type": "string" },
            "mode": { "type": "string", "enum": ["FAST", "STANDARD", "FULL"] },
            "task_source": { "type": "string" },
            "linear_issue_id": { "type": "string" },
            "linear_issue_identifier": { "type": "string" },
            "linear_issue_uuid": { "type": "string" },
            "linear_project": { "type": "string" },
            "linear_team_key": { "type": "string" },
            "service_target": { "type": "string" },
            "approval_required": { "type": "boolean" },
            "execution_policy": { "type": "string" },
            "resolved_linear_issue_identifier": { "type": "string" },
            "context_packet": { "type": "string" },
            "memory_backend": {
              "type": "string",
              "enum": ["mock", "redis", "supabase"]
            },
            "retrieved_memory_count": {
              "type": "integer",
              "minimum": 0
            },
            "context_budget": {
              "$ref": "#/$defs/context_budget"
            },
            "declared_context_refs": {
              "$ref": "#/$defs/context_refs"
            },
            "whitelisted_context_refs": {
              "$ref": "#/$defs/context_refs"
            },
            "rejected_context_refs": {
              "$ref": "#/$defs/context_refs"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "type", "mode", "status", "timestamp"],
        "properties": {
          "task_id": { "type": "string" },
          "type": { "type": "string" },
          "mode": { "type": "string", "enum": ["FAST", "STANDARD", "FULL"] },
          "status": { "type": "string", "enum": ["done", "error"] },
          "timestamp": { "type": "string" },
          "registry_record": { "type": "string" },
          "task_source": { "type": "string" },
          "linear_issue_id": { "type": "string" },
          "linear_issue_identifier": { "type": "string" },
          "linear_issue_uuid": { "type": "string" },
          "linear_project": { "type": "string" },
          "linear_team_key": { "type": "string" },
          "service_target": { "type": "string" },
          "approval_required": { "type": "boolean" },
          "execution_policy": { "type": "string" },
          "resolved_linear_issue_identifier": { "type": "string" },
          "context_packet": { "type": "string" },
          "memory_backend": {
            "type": "string",
            "enum": ["mock", "redis", "supabase"]
          },
          "retrieved_memory_count": {
            "type": "integer",
            "minimum": 0
          },
          "context_budget": {
            "$ref": "#/$defs/context_budget"
          },
          "declared_context_refs": {
            "$ref": "#/$defs/context_refs"
          },
          "whitelisted_context_refs": {
            "$ref": "#/$defs/context_refs"
          },
          "rejected_context_refs": {
            "$ref": "#/$defs/context_refs"
          }
        },
        "additionalProperties": false
      }
    },
    "version": {
      "type": "integer",
      "minimum": 1
    }
  }
}
