# Exemplo mínimo de variáveis de ambiente para o Estaleiro.
# Copie para .env e ajuste conforme o ambiente.
# .env.local pode sobrescrever valores locais.
#
# Regra canônica:
# - segredos reais devem vir do Infisical
# - Git guarda apenas placeholders, contratos e nomes
# - runtime e playbooks consomem os valores já materializados

# RUPTUR_MODE=STANDARD
# RUPTUR_LOG_LEVEL=info
# NODE_ENV=development

# Jarvis GCP memory — runtime/session memory.
# Não coloque segredos aqui. Credenciais reais devem vir do Infisical ou GCP Secret Manager.
# JARVIS_GCP_MEMORY_ENABLED=true
# JARVIS_MEMORY_CONTRACT=jarvis-gcp-adk-postgres
# JARVIS_GCP_PROJECT_ID=ruptur-jarvis-v1-68358
# JARVIS_GCP_REGION=southamerica-east1
# JARVIS_GCP_ZONE=southamerica-east1-b
# JARVIS_GCP_INSTANCE=ruptur-shipyard-01
# JARVIS_GCP_SERVICE_NAME=jarvis-agent
# JARVIS_OMEGA_SESSION_ID=OMEGA-20260411-015529-f8a43f87-jarvis-001
# JARVIS_MEMORY_SURFACE_ID=shipyard
# JARVIS_MEMORY_SESSION_ID=OMEGA-20260411-015529-f8a43f87-jarvis-001--shipyard
# JARVIS_RTK_INDEX_PATH=~/.claude/rtk/repo_index.md

# Observação:
# RUPTUR_MEMORY_BACKEND ainda controla o runner local de context packet
# e aceita os backends implementados no Shipyard: mock, redis ou supabase.
# RUPTUR_MEMORY_BACKEND=mock
